<mujoco model="robot">
  <default>
    <joint limited="false" damping="0.01" armature="0.01" frictionloss="0.01" />
    <geom condim="4" contype="1" conaffinity="15" friction="0.9 0.2 0.2" solref="0.001 2" />
  </default>

  <compiler angle="radian" meshdir="../meshes/line_follower_robot" eulerseq="zyx" autolimits="true" />

  <asset>
    <texture name="texplane" type="2d" builtin="checker" rgb1=".0 .0 .0" rgb2=".8 .8 .8" width="100"
      height="100" />
    <material name="matplane" reflectance="0." texture="texplane" texrepeat="1 1" texuniform="true" />
    <material name="default_material" rgba="0.7 0.7 0.7 1" />
    <mesh name="base.stl" file="base.stl" />
    <mesh name="base.dae" file="base.stl" />
    <mesh name="wheel.stl" file="wheel.stl" />
    <mesh name="wheel.dae" file="wheel.stl" />
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" pos="0 0 5.0"
      dir="0 0 -1" castshadow="false" />
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1" />
    <geom name="ground" type="plane" pos="0 0 0" size="10 10 0.001" material="matplane" condim="3"
      conaffinity="15" />
    <body name="base_link" pos="0 0 0.052">
      <freejoint name="root" />
      <site name="root_site" pos="0 0 0" />
      <inertial pos="0 0 0" mass="0.7" diaginertia="0.003 0.003 0.006" />
      <geom name="base_link_collision_0" type="mesh" mesh="base.stl" rgba="0 0 0 0" />
      <geom name="base_link_visual_0" material="default_material" type="mesh" mesh="base.dae" />

      <body name="left_wheel_link" pos="-0.01875 0.065 -0.019">
        <joint name="left_wheel_joint" type="hinge" axis="0 1 0" />
        <inertial pos="0.0 -0.001 0.0" mass="0.036" diaginertia="1.4072e-05 2.6303e-05 1.4072e-05" />
        <geom name="left_wheel_link_collision_0" type="mesh" mesh="wheel.stl" rgba="0 0 0 0" />
        <geom name="left_wheel_link_visual_0" material="default_material" type="mesh"
          mesh="wheel.dae" />
      </body>

      <body name="right_wheel_link" pos="-0.01875 -0.065 -0.019" quat="0.0 0.0 0.0 1.0">
        <joint name="right_wheel_joint" type="hinge" axis="0 -1 0" />
        <inertial pos="0.0 -0.001 0.0" mass="0.036" diaginertia="1.4072e-05 2.6303e-05 1.4072e-05" />
        <geom name="right_wheel_link_collision_0" type="mesh" mesh="wheel.stl" rgba="0 0 0 0" />
        <geom name="right_wheel_link_visual_0" material="default_material" type="mesh"
          mesh="wheel.dae" />
      </body>

      <!-- Caster: fixed sphere, no joints — slides freely on ground. Stable alternative to
           the 3-DOF yaw/roll/pitch chain which causes numerical oscillation in MuJoCo -->
      <body name="caster_link" pos="0.093283 0 -0.047">
        <inertial pos="0 0 0" mass="0.001" diaginertia="4e-08 4e-08 4e-08" />
        <geom name="caster_geom" type="sphere" size="0.005"
          friction="0.01 0.005 0.005" material="default_material" />
      </body>
      <body name="camera_link" pos="0.134 0 0.0225" euler="-1.5707 0 0">
        <camera name="line_camera" mode="fixed" pos="0 0 0" euler="0 0 0" fovy="60" />
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="left_wheel_joint_ctrl" joint="left_wheel_joint" ctrlrange="-20 20"
      ctrllimited="true" />
    <velocity name="right_wheel_joint_ctrl" joint="right_wheel_joint" ctrlrange="-20 20"
      ctrllimited="true" />
  </actuator>

</mujoco>