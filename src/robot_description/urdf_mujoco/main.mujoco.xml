<mujoco model="robot">
    <default>
        <joint limited="false" damping="0.01" armature="0.01" frictionloss="0.01" />
        <geom condim="4" contype="1" conaffinity="15" friction="0.9 0.2 0.2" solref="0.001 2" />
    </default>

    <compiler angle="radian" meshdir="../meshes/line_follower_robot" eulerseq="zyx"
        autolimits="true" />

    <asset>
        <texture name="texplane" type="2d" builtin="checker" rgb1=".0 .0 .0" rgb2=".8 .8 .8"
            width="100"
            height="100" />
        <material name="matplane" reflectance="0." texture="texplane" texrepeat="1 1"
            texuniform="true" />
        <material name="default_material" rgba="0.7 0.7 0.7 1" />
        <mesh name="base.stl" file="base.stl" />
        <mesh name="wheel.stl" file="wheel.stl" />

        <!-- Load the stage obj; explicitly defining the material to ensure texture loads -->
        <mesh name="stage" file="../stage/stage.obj" />
        <texture name="stage_tex" type="2d" file="../meshes/stage/stage.png" />
        <material name="stage_mat" texture="stage_tex" specular="0.0" shininess="0.0" />
    </asset>

    <worldbody>
        <light directional="true" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" pos="0 0 5.0"
            dir="0 0 -1" castshadow="false" />
        <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4"
            dir="0 0 -1" />

        <body name="stage_body" pos="0 0 0.001" euler="0 0 1.570796">
            <geom name="stage_geom" type="mesh" mesh="stage" material="stage_mat" condim="3"
                conaffinity="15" />
        </body>

        <include file="robot_1.mujoco.xml" />
        <include file="robot_2.mujoco.xml" />
        <include file="robot_3.mujoco.xml" />
        <include file="robot_4.mujoco.xml" />
        <include file="robot_5.mujoco.xml" />
        <include file="robot_6.mujoco.xml" />
        <include file="robot_7.mujoco.xml" />
        <include file="robot_8.mujoco.xml" />
        <include file="robot_9.mujoco.xml" />

    </worldbody>

    <actuator>
        <velocity name="left_wheel_joint_ctrl_1" joint="left_wheel_joint_1" ctrlrange="-20 20"
            ctrllimited="true" />
        <velocity name="right_wheel_joint_ctrl_1" joint="right_wheel_joint_1" ctrlrange="-20 20"
            ctrllimited="true" />

        <velocity name="left_wheel_joint_ctrl_2" joint="left_wheel_joint_2" ctrlrange="-20 20"
            ctrllimited="true" />
        <velocity name="right_wheel_joint_ctrl_2" joint="right_wheel_joint_2" ctrlrange="-20 20"
            ctrllimited="true" />

        <velocity name="left_wheel_joint_ctrl_3" joint="left_wheel_joint_3" ctrlrange="-20 20"
            ctrllimited="true" />
        <velocity name="right_wheel_joint_ctrl_3" joint="right_wheel_joint_3" ctrlrange="-20 20"
            ctrllimited="true" />

        <velocity name="left_wheel_joint_ctrl_4" joint="left_wheel_joint_4" ctrlrange="-20 20"
            ctrllimited="true" />
        <velocity name="right_wheel_joint_ctrl_4" joint="right_wheel_joint_4" ctrlrange="-20 20"
            ctrllimited="true" />

        <velocity name="left_wheel_joint_ctrl_5" joint="left_wheel_joint_5" ctrlrange="-20 20"
            ctrllimited="true" />
        <velocity name="right_wheel_joint_ctrl_5" joint="right_wheel_joint_5" ctrlrange="-20 20"
            ctrllimited="true" />

        <velocity name="left_wheel_joint_ctrl_6" joint="left_wheel_joint_6" ctrlrange="-20 20"
            ctrllimited="true" />
        <velocity name="right_wheel_joint_ctrl_6" joint="right_wheel_joint_6" ctrlrange="-20 20"
            ctrllimited="true" />

        <velocity name="left_wheel_joint_ctrl_7" joint="left_wheel_joint_7" ctrlrange="-20 20"
            ctrllimited="true" />
        <velocity name="right_wheel_joint_ctrl_7" joint="right_wheel_joint_7" ctrlrange="-20 20"
            ctrllimited="true" />

        <velocity name="left_wheel_joint_ctrl_8" joint="left_wheel_joint_8" ctrlrange="-20 20"
            ctrllimited="true" />
        <velocity name="right_wheel_joint_ctrl_8" joint="right_wheel_joint_8" ctrlrange="-20 20"
            ctrllimited="true" />

        <velocity name="left_wheel_joint_ctrl_9" joint="left_wheel_joint_9" ctrlrange="-20 20"
            ctrllimited="true" />
        <velocity name="right_wheel_joint_ctrl_9" joint="right_wheel_joint_9" ctrlrange="-20 20"
            ctrllimited="true" />
    </actuator>

</mujoco>